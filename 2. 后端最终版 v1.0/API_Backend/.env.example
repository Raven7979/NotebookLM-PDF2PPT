# NotePDF 2 PPT Backend Configuration Example
# Copy this file to .env and fill in the actual values

# Environment (development or production)
ENV=production
API_BASE_URL=https://yourdomain.com

# Database URL (SQLite)
# SQLALCHEMY_DATABASE_URL=sqlite:///./sql_app.db

# Nano Banana Pro API Key (for inpainting)
NANO_API_KEY=your-nano-api-key

# Aliyun SMS config
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sms-sign-name
ALIYUN_SMS_TEMPLATE_CODE=your-sms-template-code

# Hupijiao Payment
HUPIJIAO_APPID=your-hupijiao-appid
HUPIJIAO_APPSECRET=your-hupijiao-appsecret

# Security (JWT)
# SECRET_KEY=your-secret-key-for-jwt
# ACCESS_TOKEN_EXPIRE_MINUTES=43200
